services:
  api-{{ .ProjectName }}:
    build: .
    ports:
      - "{{ .Values.PORT }}:{{ .Values.PORT }}"
    environment:
      DATABASE_URL: "postgres://admin:password@{{ .Values.DB_HOST }}:5432/myapp"
      REDIS_URL: "redis://{{ .Values.REDIS_HOST }}:6379"
    depends_on:
      - {{ .Values.DB_HOST }}
      - {{ .Values.REDIS_HOST }}
